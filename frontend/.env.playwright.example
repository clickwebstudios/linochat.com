# Playwright Environment Variables for Testing

# Test Credentials
TEST_EMAIL=admin@clickwebstudio.com
TEST_PASSWORD=123123123

# Base URL for testing
# Use localhost for local development
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Or use production for testing against live site
# PLAYWRIGHT_BASE_URL=https://linochat.com

# CI mode (set automatically in CI)
# CI=true

# Additional configuration options
# PLAYWRIGHT_HEADLESS=true
# PLAYWRIGHT_SLOW_MO=0
