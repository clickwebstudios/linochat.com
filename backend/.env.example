APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Frontend URL for password reset, invite links, etc.
# Local: http://localhost:5173 | Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher

# Pusher (real-time WebSocket) - get credentials from dashboard.pusher.com
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=us3

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail - REQUIRED for invitation emails to be sent!
# Default "log" driver writes to storage/logs - emails are NOT sent to recipients.
# For production: use smtp, mailgun, ses, postmark, or resend.
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"
# For Mailgun: MAIL_MAILER=mailgun, MAILGUN_DOMAIN=, MAILGUN_SECRET=
# For SES: MAIL_MAILER=ses, AWS_ACCESS_KEY_ID=, AWS_SECRET_ACCESS_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CORS: Widget embedding - * for all sites, or comma-separated origins
# CORS_WIDGET_ALLOWED_ORIGINS=*
# CORS_WIDGET_ALLOWED_ORIGINS=https://clickwebstudio.com,https://www.clickwebstudio.com

# Frubix CRM Integration (OAuth2)
# Get credentials from your Frubix account settings → API / OAuth
FRUBIX_URL=https://frubix.com
FRUBIX_CLIENT_ID=
FRUBIX_CLIENT_SECRET=
FRUBIX_REDIRECT_URI="${APP_URL}/api/integrations/frubix/callback"
